{
  "name": "threadlocked",
  "main": "./dist/worker.mjs",
  "compatibility_date": "2026-06-01",
  "build": {
    "command": "npm run build"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  }
}
